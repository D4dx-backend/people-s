# Development API Configuration
# Use the Vite dev-server proxy path — no CORS issues since browser sees it as same-origin
VITE_API_URL=http://localhost:8080/api

# Environment
VITE_NODE_ENV=development

# Multi-tenant: Set the franchise slug for local development.
# On production this is derived automatically from the subdomain.
# Available slugs: 'people' (People's Foundation) | 'bz' (Baithuzzakath)
VITE_FRANCHISE_SLUG=people
